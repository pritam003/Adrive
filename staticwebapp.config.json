{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/.auth/*", "/*.{css,js,svg,png,jpg,jpeg,gif,ico,woff,woff2,ttf}"]
  },
  "mimeTypes": {
    ".json": "application/json"
  },
  "routes": [
    { "route": "/api/me", "allowedRoles": ["anonymous", "authenticated"] },
    { "route": "/api/getRoles", "allowedRoles": ["anonymous", "authenticated"] },
    { "route": "/api/share/get", "allowedRoles": ["anonymous", "authenticated"] },
    { "route": "/share/*", "allowedRoles": ["anonymous", "authenticated"] },
    { "route": "/login", "rewrite": "/.auth/login/aad", "allowedRoles": ["anonymous", "authenticated"] },
    { "route": "/logout", "rewrite": "/.auth/logout", "allowedRoles": ["anonymous", "authenticated"] },
    { "route": "/api/*", "allowedRoles": ["authenticated"] },
    { "route": "/*", "allowedRoles": ["anonymous", "authenticated"] }
  ],
  "responseOverrides": {
    "401": { "redirect": "/.auth/login/aad", "statusCode": 302 }
  }
}
