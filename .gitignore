# ═══════════════════════════════════════
# ROOT — applies to all sub-projects
# ═══════════════════════════════════════

# Root-level Gradle wrapper cache (generated by Android Studio)
.gradle/
local.properties

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# Editor / IDE
.idea/caches
.idea/libraries
.idea/modules.xml
.idea/workspace.xml
.idea/navEditor.xml
.idea/assetWizardSettings.xml
.idea/*.xml
!.idea/gradle.xml
!.idea/runConfigurations/
*.iml

# Log files
*.log

# Secrets — never commit
*.env
*.env.*
secrets.properties
signing.properties

# ═══════════════════════════════════════
# mobileversion/ — Android
# ═══════════════════════════════════════

# Built application files
mobileversion/**/*.apk
mobileversion/**/*.aab
mobileversion/**/*.ap_
mobileversion/**/*.dex
mobileversion/**/*.class

# Gradle build output
mobileversion/.gradle/
mobileversion/build/
mobileversion/app/build/

# Local configuration (SDK path)
mobileversion/local.properties

# ProGuard generated
mobileversion/proguard/

# External native build
mobileversion/.externalNativeBuild/
mobileversion/.cxx/

# Google Services
mobileversion/google-services.json

# Signing
mobileversion/*.jks
mobileversion/*.keystore
mobileversion/keystore.properties

# Android Studio captures
mobileversion/captures/

# ═══════════════════════════════════════
# webversion/ — Web Application
# ═══════════════════════════════════════

# Dependencies
webversion/node_modules/
webversion/.pnp
webversion/.pnp.*

# Build output
webversion/dist/
webversion/.next/
webversion/out/
webversion/build/
webversion/.svelte-kit/
webversion/.nuxt/
webversion/.output/
webversion/.vite/

# Cache
webversion/.cache/
webversion/.parcel-cache/
webversion/.eslintcache
webversion/.stylelintcache

# Test coverage
webversion/coverage/
webversion/.nyc_output/

# Debug
webversion/npm-debug.log*
webversion/yarn-debug.log*
webversion/yarn-error.log*

# Local env files
webversion/.env
webversion/.env.local
webversion/.env.development.local
webversion/.env.test.local
webversion/.env.production.local

# Vercel / Netlify / Azure deployment artifacts
webversion/.vercel/
webversion/.netlify/
