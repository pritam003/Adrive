# Built application files
*.apk
*.aab
*.ap_
*.dex

# Files for the ART/Dalvik VM
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
build/
app/build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/caches
.idea/libraries
.idea/modules.xml
.idea/workspace.xml
.idea/navEditor.xml
.idea/assetWizardSettings.xml
.idea/*.xml
!.idea/gradle.xml
!.idea/runConfigurations/

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Google Services (e.g. APIs or Firebase)
google-services.json

# Versioning key (keep private)
keystore.properties
*.jks
*.keystore

# macOS
.DS_Store

# Windows
Thumbs.db

# NPM (if React Native)
node_modules/
npm-debug.log

# Signing configs
signing.properties

# Secrets
*.env
secrets.properties
